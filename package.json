  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "files": [
    "lib",
    "bin",
    "README.md"
  ]
}
